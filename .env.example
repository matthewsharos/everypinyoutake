# Copy to .env and fill in. The anon key is public (safe in the browser); never put the service key here in a public repo.
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin — SERVER ONLY (no PUBLIC_ prefix). Set these in Cloudflare Pages too.
ADMIN_PIN=6400
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
